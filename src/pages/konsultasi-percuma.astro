---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Konsultasi Takaful Percuma | Dr. Takaful" description="Dapatkan konsultasi takaful percuma dari Dr. Takaful (Hana). Semak keperluan perlindungan anda tanpa sebarang komitmen.">



  <!-- Header -->
  

  <!-- FORM CARD SECTION -->
  <section id="health-form" class="py-12 md:py-20 px-6">
    <div class="max-w-lg mx-auto bg-white p-8 rounded-2xl shadow-2xl border border-rose-100">
      <div class="text-center">
        <h1 class="text-3xl font-bold text-rose-700 mb-2">Satu Langkah Mudah Untuk Bermula</h1>
        <p class="text-gray-600 mb-8">Isi nama dan nombor telefon anda. Saya akan hubungi anda di WhatsApp untuk sesi konsultasi percuma.</p>
      </div>

      <div class="grid grid-cols-1 gap-6">
        <!-- Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700">Nama Penuh</label>
          <input type="text" id="name" class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-rose-500 focus:border-rose-500" placeholder="cth: Abdul Rahman">
        </div>

        <!-- Phone Number -->
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700">No. Telefon (WhatsApp)</label>
          <input type="tel" id="phone" class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-rose-500 focus:border-rose-500" placeholder="cth: 0123456789">
        </div>

        <!-- Submit Button -->
        <div class="text-center pt-4">
          <button onclick="sendWhatsApp()" class="w-full bg-rose-600 text-white py-3 rounded-lg hover:bg-rose-700 transition font-medium text-lg">
            Hantar & Minta Konsultasi ðŸ’¬
          </button>
          <p id="formMessage" class="text-center text-sm mt-3 text-gray-600">Konsultasi percuma, 100% tanpa paksaan.</p>
        </div>
      </div>
    </div>
  </section>

  

</BaseLayout>


---
// BaseLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../global.css';

interface Props {
  title?: string;
  description?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const { 
  title = "Rancang Kewangan: Cara Lindungi Gaji & Keluarga | Dr. Takaful", 
  description = "Takut hilang gaji? Dr. Takaful bantu anda rancang kewangan dengan 4 langkah mudah untuk sediakan 'gaji kedua' bila diuji sakit kritikal, hilang upaya atau kematian.",
  hideNav = false,
  hideFooter = false
} = Astro.props;
---
<!DOCTYPE html>
<html lang="ms" class="scroll-smooth">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>
    (function (w, d, s, l, i) {
      w[l] = w[l] || []; w[l].push({
        'gtm.start': new Date().getTime(), event: 'gtm.js'
      }); var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
          'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', 'GTM-KFWGX5DS');
  </script>
  <!-- End Google Tag Manager -->
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-F51SWCERD8" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-F51SWCERD8');
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#fb7185">

  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Canonical -->
  <link rel="canonical" href={Astro.url.href}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Takaful by Hana">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={Astro.url.href}>
  <meta property="og:image" content="https://drtakaful.com/images/og-preview.png">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://drtakaful.com/images/og-preview.png">

  <!-- Favicon -->
  <link rel="icon" href="/favicon.png" type="image/x-icon">
  <link rel="icon" type="image/png" sizes="16x16" href="/src/android-chrome-192x192.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/src/android-chrome-512x512.png">
  <link rel="manifest" href="https://drtakaful.com/site.webmanifest">
</head>

<body class="bg-gray-50 text-gray-800 antialiased selection:bg-gray-100 selection:text-gray-900">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KFWGX5DS" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  {!hideNav && <Header />}

  <main>
    <slot />
  </main>

  {!hideFooter && <Footer />}

  <!-- Sticky CTA Button -->
  <a href="https://wa.me/60132522587?text=Assalamualaikum%20Dr.%20Hana%2C%0A%0ASaya%20nak%20tahu%20lebih%20lanjut%20tentang%20Takaful%20untuk%20lindungi%20gaji%20%26%20keluarga%20saya.%20Boleh%20bantu%20saya%20semak%20kelayakan%20%26%20harga%3F%0A%0ATerima%20kasih%21%20%F0%9F%99%8F"
    data-wa-source="sticky-cta" data-wa-intent="Sticky CTA" target="_blank" id="sticky-cta"
    class="wa-cta hidden fixed bottom-6 right-6 bg-[#25D366] text-white pl-4 pr-6 py-4 rounded-full shadow-2xl hover:bg-[#20BA5A] active:scale-95 transition-all z-50 font-bold text-sm flex items-center gap-3 group">
    <span class="relative flex h-3 w-3">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
      <span class="relative inline-flex rounded-full h-3 w-3 bg-white"></span>
    </span>
    <span class="leading-none">WhatsApp Dr. Hana</span>
  </a>

  <!-- Exit-Intent Popup -->
  <div id="exit-popup" class="hidden fixed inset-0 bg-gray-900/80 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-8 text-center relative transform transition-all scale-95 opacity-0" id="popup-content">
      <button id="close-popup" class="absolute top-4 right-4 text-gray-300 hover:text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="text-4xl mb-4">👋</div>
      <h3 class="text-2xl font-bold text-gray-900 mb-2">Nanti Dulu!</h3>
      <p class="text-gray-500 mb-8 leading-relaxed">Setiap tahun anda bertangguh, premium takaful boleh naik
        <strong>3-8%</strong>. Kunci harga rendah anda hari ini.
      </p>
      <a href="/#borang-konsultasi" id="popup-cta" class="block w-full bg-gray-900 text-white px-6 py-3 rounded-xl font-medium hover:bg-gray-800 transition shadow-lg">
        Dapatkan Pelan Percuma
      </a>
    </div>
  </div>

  <script src="/short-url-helper.js" defer is:inline></script>
  <script src="/main.js" defer is:inline></script>
</body>
</html>
